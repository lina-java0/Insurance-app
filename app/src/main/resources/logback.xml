<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOGS" value="./logs" />

    <!-- Консольный аппендер -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Общий аппендер для приложения -->
    <appender name="FILE_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS}/application-logger.log</file>
        <immediateFlush>true</immediateFlush>
        <append>true</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOGS}/archived/application-logger-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>1MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <!-- Аппендер для V1 -->
    <appender name="REQUEST_RESPONSE_FILE_APPENDER_V1" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS}/request-response-v1-logger.log</file>
        <immediateFlush>true</immediateFlush>
        <append>true</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOGS}/archived/request-response-v1-logger-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>1MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <!-- Аппендер для V2 -->
    <appender name="REQUEST_RESPONSE_FILE_APPENDER_V2" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS}/request-response-v2-logger.log</file>
        <immediateFlush>true</immediateFlush>
        <append>true</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOGS}/archived/request-response-v2-logger-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>1MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <!-- Общий аппендер для всех логов -->
    <appender name="ALL_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS}/all-logger.log</file>
        <immediateFlush>true</immediateFlush>
        <append>true</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOGS}/archived/all-logger-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>1MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <!-- Root логгер -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="ALL_APPENDER" />
    </root>

    <!-- Логгеры V1 -->
    <logger name="org.javaguru.travel.insurance.rest.v1.TravelCalculatePremiumResponseLoggerV1" level="INFO" additivity="true">
        <appender-ref ref="REQUEST_RESPONSE_FILE_APPENDER_V1" />
    </logger>
    <logger name="org.javaguru.travel.insurance.rest.v1.TravelCalculatePremiumRequestLoggerV1" level="INFO" additivity="true">
        <appender-ref ref="REQUEST_RESPONSE_FILE_APPENDER_V1" />
    </logger>

    <!-- Логгеры V2 -->
    <logger name="org.javaguru.travel.insurance.rest.v2.TravelCalculatePremiumResponseLoggerV2" level="INFO" additivity="true">
        <appender-ref ref="REQUEST_RESPONSE_FILE_APPENDER_V2" />
    </logger>
    <logger name="org.javaguru.travel.insurance.rest.v2.TravelCalculatePremiumRequestLoggerV2" level="INFO" additivity="true">
        <appender-ref ref="REQUEST_RESPONSE_FILE_APPENDER_V2" />
    </logger>

    <!-- Логгер для приложения -->
    <logger name="org.javaguru.travel.insurance" level="INFO" additivity="true">
        <appender-ref ref="FILE_APPENDER" />
    </logger>

</configuration>